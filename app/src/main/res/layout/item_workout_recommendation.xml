<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    android:background="@drawable/bg_workout_card"
    android:clickable="true"
    android:focusable="true"
    android:padding="20dp">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/iv_rec_icon"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:background="@color/light_blue_bg"
        android:padding="16dp"
        android:src="@drawable/ic_dumbbell"
        app:shapeAppearanceOverlay="@style/RoundedIcon" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:layout_marginStart="20dp"
        android:layout_toEndOf="@id/iv_rec_icon"
        android:layout_toStartOf="@id/btn_rec_start"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_rec_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="2"
            android:text="Workout Name"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_rec_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Category • Difficulty"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />
    </LinearLayout>

    <Button
        android:id="@+id/btn_rec_start"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:background="@drawable/bg_blue_button"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:paddingHorizontal="20dp"
        android:paddingVertical="10dp"
        android:text="Mulai"
        android:textAllCaps="false"
        android:textColor="@color/white_absolute"
        android:textSize="14sp"
        android:textStyle="bold"
        app:backgroundTint="@null" />

</RelativeLayout>