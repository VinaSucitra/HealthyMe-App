<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_detail_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/page_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_detail_header"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingBottom="40dp">

            <LinearLayout
                android:id="@+id/btn_back"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:padding="8dp"
                android:background="?attr/selectableItemBackground">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_back"
                    app:tint="@color/white_absolute" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Kembali"
                    android:textColor="@color/white_absolute"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_detail_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Barbell\nBench Press"
                android:textColor="@color/header_text_color"
                android:textSize="28sp"
                android:textStyle="bold"
                android:lineSpacingExtra="4dp" />

            <!-- Vertical Bars Info -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="32dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_detail_bar_1"
                    android:gravity="center_horizontal"
                    android:paddingTop="16dp">
                    <TextView
                        android:id="@+id/tv_bar_difficulty"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Beginner"
                        android:textColor="@color/white_absolute"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_detail_bar_2"
                    android:gravity="center_horizontal"
                    android:paddingTop="16dp">
                    <TextView
                        android:id="@+id/tv_bar_muscle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chest"
                        android:textColor="#80FFFFFF"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_detail_bar_3"
                    android:gravity="center_horizontal"
                    android:paddingTop="16dp">
                    <TextView
                        android:id="@+id/tv_bar_type"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Strength"
                        android:textColor="#80FFFFFF"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Muscles Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OTOT YANG DILATIH"
                android:textColor="@color/splash_cyan"
                android:textSize="13sp"
                android:letterSpacing="0.05"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="72dp"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_tip_card"
                    android:gravity="center"
                    android:paddingVertical="12dp">
                    <LinearLayout android:orientation="vertical" android:gravity="center" android:layout_width="match_parent" android:layout_height="wrap_content">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_chest" app:tint="@color/splash_cyan" />
                        <TextView android:layout_marginTop="8dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Chest" android:textColor="@color/text_secondary" android:textSize="10sp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="72dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_tip_card"
                    android:gravity="center"
                    android:paddingVertical="12dp">
                    <LinearLayout android:orientation="vertical" android:gravity="center" android:layout_width="match_parent" android:layout_height="wrap_content">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_tricep" app:tint="@color/splash_cyan" />
                        <TextView android:layout_marginTop="8dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tricep" android:textColor="@color/text_secondary" android:textSize="10sp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="72dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_tip_card"
                    android:gravity="center"
                    android:paddingVertical="12dp">
                    <LinearLayout android:orientation="vertical" android:gravity="center" android:layout_width="match_parent" android:layout_height="wrap_content">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_shoulder" app:tint="@color/splash_cyan" />
                        <TextView android:layout_marginTop="8dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Shoulder" android:textColor="@color/text_secondary" android:textSize="10sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Instructions Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="INSTRUKSI"
                android:textColor="@color/splash_cyan"
                android:textSize="13sp"
                android:letterSpacing="0.05"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_detail_instructions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_instruction_box"
                android:padding="20dp"
                android:lineSpacingExtra="4dp"
                android:text="Berbaring di bench, pegang barbel selebar bahu. Turunkan ke dada perlahan, tahan 1 detik, lalu dorong ke atas. 3 set x 10 repetisi."
                android:textColor="@color/text_primary"
                android:textSize="14sp" />

            <!-- Action Buttons -->
            <Button
                android:id="@+id/btn_favorite"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:background="@drawable/bg_blue_button"
                app:backgroundTint="@null"
                android:text="Tambah ke Favorit"
                android:textAllCaps="false"
                android:textColor="@color/white_absolute"
                android:textSize="15sp"
                android:textStyle="bold"
                app:icon="@android:drawable/btn_star_big_off"
                app:iconGravity="textStart"
                app:iconPadding="8dp" />

            <Button
                android:id="@+id/btn_start_workout"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_play_button"
                app:backgroundTint="@null"
                android:text="Mulai Workout"
                android:textAllCaps="false"
                android:textColor="@color/blue_button"
                android:textSize="15sp"
                android:textStyle="bold"
                app:icon="@drawable/ic_play"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:iconTint="@color/blue_button" />

        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>